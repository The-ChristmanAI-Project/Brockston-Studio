# BROCKSTON Studio Environment Configuration
# Copy this file to .env and configure with your settings

# ==========================================
# SERVER CONFIGURATION
# ==========================================

# Host and port for the BROCKSTON Studio server
BROCKSTON_HOST=127.0.0.1
BROCKSTON_PORT=9003

# IDE Board frontend port (main.py)
IDE_PORT=5055

# UltimateEV code mechanic port
ULTIMATEEV_PORT=5174

# ==========================================
# AI MODEL ENDPOINTS
# ==========================================

# URL where the BROCKSTON reasoning engine is running
# Default: http://localhost:9003 (Brockston educator backend)
BROCKSTON_BASE_URL=http://localhost:9003

# URL where the UltimateEV coding assistant is running
# Default: http://localhost:5174
ULTIMATEEV_BASE_URL=http://localhost:5174

# Default AI model to use (options: brockston, ultimateev)
DEFAULT_MODEL=brockston

# Model split for low lag on vocal/team chat vs heavy code
# GENERAL: fast/small model for chat, vocal responses, being comms (e.g. llama3.2, qwen2.5:7b)
LLM_MODEL_GENERAL=llama3.2
# CODER: heavy/accurate for code analysis, suggest_fix, execution paths
LLM_MODEL_CODER=qwen2.5-coder:32b

# Being Agent compute loop (ls/read/patch/run) — uses CODER, not GENERAL
BEING_AGENT_MODEL=qwen2.5-coder:32b
BEING_AGENT_MAX_STEPS=6
BEING_AGENT_OLLAMA_TIMEOUT_SEC=180

# TTS read-aloud — chunk size (full replies, not 600-char clips)
TTS_MAX_CHUNK_CHARS=3500
# Force male Brockston voice for all read-aloud (optional override)
# TTS_READ_BEING=brockston

# ==========================================
# EXTERNAL API KEYS
# ==========================================

# Anthropic Claude API Configuration
# Get your API key at https://console.anthropic.com/
# Leave empty to disable Claude features
ANTHROPIC_API_KEY=

# NVIDIA — each being has its OWN nvapi key (do not share across Kimi/Nemo/Gemma)
# Legacy NVIDIA_API_KEY still works as fallback for Kimi/Nemo if being-specific key is empty.

# Kimi K2.6 — learning tutor
NVIDIA_KIMI_API_KEY=
NVIDIA_CHAT_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_KIMI_MODEL=moonshotai/kimi-k2.6
NVIDIA_KIMI_MAX_TOKENS=16384
NVIDIA_KIMI_TEMPERATURE=1.0
NVIDIA_KIMI_TOP_P=1.0
BROCKSTON_KIMI_URL=http://localhost:9003/kimi/interact

# Nemo — Nemotron 3 Ultra (partner + code lab)
NVIDIA_NEMO_API_KEY=
NVIDIA_NEMO_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_NEMO_TEMPERATURE=1
NVIDIA_NEMO_TOP_P=0.95
NVIDIA_NEMO_MAX_TOKENS=16384
NVIDIA_NEMO_EXTRA_BODY={"chat_template_kwargs":{"enable_thinking":true},"reasoning_budget":16384}

# Gemma (optional GLM instructor)
NVIDIA_GEMMA_API_KEY=
NVIDIA_GEMMA_MODEL=google/gemma-4-31b-it
NVIDIA_GEMMA_TEMPERATURE=1
NVIDIA_GEMMA_TOP_P=0.95
NVIDIA_GEMMA_MAX_TOKENS=16384

# Speech Services Configuration (optional)
# API key for speech-to-text/text-to-speech integration
# Leave empty to use mock mode (for development without speech features)
SPEECH_SERVICE_API_KEY=

# GitHub Personal Access Token (optional)
# Required for: cloning private repositories, increasing rate limits
#
# How to create a GitHub PAT:
# 1. Go to https://github.com/settings/tokens
# 2. Click "Generate new token" → "Generate new token (classic)"
# 3. Give it a name (e.g., "BROCKSTON Studio")
# 4. Select scopes:
#    - For public repos only: leave all unchecked (or check "public_repo")
#    - For private repos: check "repo" (full control of private repositories)
# 5. Click "Generate token"
# 6. Copy the token (starts with ghp_) and paste below
#
# IMPORTANT: Keep this token secret! Add .env to .gitignore
# Leave empty if you only need to clone public repositories
GITHUB_TOKEN=

# ==========================================
# WORKSPACE CONFIGURATION
# ==========================================

# Root directory for file operations
# This is where BROCKSTON Studio can read/write files
# Default: ~/Code (your home directory + Code folder)
# Examples:
#   ~/Code                    (recommended default)
#   ~/Projects                (alternative)
#   /Users/YourName/Code      (absolute path on macOS)
#   /home/user/workspace      (absolute path on Linux)
#   C:\Users\YourName\Code     (absolute path on Windows)
# Default folder when the IDE opens (beings + explorer + terminal start here)
# Use ~/Code for your projects; change anytime. Last-opened folder is remembered in the browser.
BROCKSTON_WORKSPACE=~/Code

# Local Ollama endpoint
OLLAMA_BASE_URL=http://127.0.0.1:11434
