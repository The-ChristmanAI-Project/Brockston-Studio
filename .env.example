# =============================================================================
# Brockston-Studio — Environment Configuration
# This repo only. NOT the separate BROCKSTON stack (~/BROCKSTON).
# Copy to .env and fill in your keys. Loaded by start.sh from repo root.
# =============================================================================

# -----------------------------------------------------------------------------
# Brockston-Studio services (ports + URLs)
# -----------------------------------------------------------------------------
STUDIO_HOST=127.0.0.1
STUDIO_BACKEND_PORT=9003
IDE_PORT=5055
ULTIMATEEV_PORT=5174

STUDIO_BACKEND_URL=http://localhost:9003
ULTIMATEEV_BASE_URL=http://localhost:5174

# -----------------------------------------------------------------------------
# Studio IDE — default project folder
# -----------------------------------------------------------------------------
STUDIO_WORKSPACE=~/Code

# -----------------------------------------------------------------------------
# OLLAMA — local models (Family chat + Being Agent tools)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_API_KEY=

LLM_MODEL_GENERAL=llama3.2
LLM_MODEL_CODER=qwen2.5-coder:32b

BEING_AGENT_MODEL=qwen2.5-coder:32b
BEING_AGENT_MAX_STEPS=6
BEING_AGENT_OLLAMA_TIMEOUT_SEC=180

BEING_AGENT_REVIEW_MAX_STEPS=12
BEING_AGENT_REVIEW_MIN_TOOLS=5
BEING_AGENT_REVIEW_TOOLS_PER_STEP=8
BEING_AGENT_REVIEW_NUM_PREDICT=1024

# -----------------------------------------------------------------------------
# ANTHROPIC — Claude instructor
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# NVIDIA integrate API — per-being keys (do NOT share across Kimi/Nemo/Gemma)
# -----------------------------------------------------------------------------
NVIDIA_CHAT_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Kimi K2.6 — learning tutor
NVIDIA_KIMI_API_KEY=
NVIDIA_KIMI_MODEL=moonshotai/kimi-k2.6
NVIDIA_KIMI_MAX_TOKENS=16384
NVIDIA_KIMI_TEMPERATURE=1.0
NVIDIA_KIMI_TOP_P=1.0
STUDIO_KIMI_URL=http://localhost:9003/kimi/interact

# Nemo — Nemotron 3 Ultra (OpenAI client @ integrate.api.nvidia.com/v1)
NVIDIA_NEMO_API_KEY=
NVIDIA_NEMO_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NEMO_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_NEMO_STREAM=true
NVIDIA_NEMO_TEMPERATURE=1
NVIDIA_NEMO_TOP_P=0.95
NVIDIA_NEMO_MAX_TOKENS=16384
NVIDIA_NEMO_EXTRA_BODY='{"chat_template_kwargs":{"enable_thinking":true},"reasoning_budget":16384}'

# Gemma — optional GLM instructor
NVIDIA_GEMMA_API_KEY=
NVIDIA_GEMMA_MODEL=google/gemma-4-31b-it
NVIDIA_GEMMA_TEMPERATURE=1
NVIDIA_GEMMA_TOP_P=0.95
NVIDIA_GEMMA_MAX_TOKENS=16384

# -----------------------------------------------------------------------------
# VOICE & SPEECH (Christman Sound / local TTS)
# -----------------------------------------------------------------------------
TTS_MAX_CHUNK_CHARS=3500

# -----------------------------------------------------------------------------
# INTEGRATIONS (optional)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
PERPLEXITY_API_KEY=

# Optional Bedrock LLM fallback — voice uses Christman Sound, not AWS Polly
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

ANTHROPIC_AWS_API_KEY=
ANTHROPIC_AWS_WORKSPACE_ID=